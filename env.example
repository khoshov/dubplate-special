# =============================================
# БАЗОВЫЕ НАСТРОЙКИ DJANGO
# =============================================
DEBUG=True
SILK_ENABLED=True
SECRET_KEY=change-me
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# =============================================
# БАЗА ДАННЫХ (PostgreSQL)
# =============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# =============================================
# НАСТРОЙКИ Discogs API
# =============================================
DISCOGS_API_KEY=
DISCOGS_USER_AGENT=VinylCatalog/1.0
DISCOGS_COLLECTION_USERNAME=DubplateSpecial

# =============================================
# НАСТРОЙКИ SMS API
# =============================================
SMS_API_KEY=
SMS_PROVIDER=sms_ru
SMS_TEST_MODE=True

# =============================================
# НАСТРОЙКИ VK API
# =============================================
VK_GROUP_ID=225812294
VK_ACCESS_TOKEN=

# =============================================
# НАСТРОЙКИ ЛОГИРОВАНИЯ
# =============================================
# APP_LOG_LEVEL: DEBUG/INFO/NOTICE/WARNING/ERROR/CRITICAL
# APP_LOG_FORMAT: text/json
APP_LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=WARNING
APP_LOG_FORMAT=text
APP_LOG_DESTINATION=stdout
APP_LOG_COLOR=true
APP_LOG_FILE_PATH=logs/app.log

# =============================================
# НАСТРОЙКИ CELERY / REDIS
# =============================================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1
CELERY_TASK_TIME_LIMIT=1800
CELERY_TASK_SOFT_TIME_LIMIT=1500
YOUTUBE_COOKIE_FILE=/app/runtime/youtube-cookies.txt
YOUTUBE_BROWSER_PROFILE_DIR=/app/runtime/youtube-browser-profile
YOUTUBE_SESSION_LOCK_FILE=/app/runtime/youtube-session-refresh.lock
YOUTUBE_YTDLP_CACHE_DIR=/app/runtime/yt-dlp-cache
YOUTUBE_JS_RUNTIME=deno
YOUTUBE_JS_RUNTIME_PATH=/usr/local/bin/deno
YOUTUBE_BROWSER_NAME=chromium
YOUTUBE_BROWSER_KEYRING=BASICTEXT
YOUTUBE_REMOTE_COMPONENTS=ejs:github
YOUTUBE_SESSION_REFRESH_URL=https://www.youtube.com/
YOUTUBE_SESSION_LOGIN_URL=https://accounts.google.com/ServiceLogin?service=youtube
YOUTUBE_SESSION_REFRESH_WAIT_MS=3000
YOUTUBE_SESSION_LOGIN_TIMEOUT_MS=900000
YOUTUBE_SESSION_LOGIN_POLL_MS=2000
YOUTUBE_SESSION_LOGIN_SUCCESS_WAIT_MS=10000
YOUTUBE_SESSION_LOCK_WAIT_MS=15000
YOUTUBE_SESSION_RECOVERY_RETRY_ENABLED=True
YOUTUBE_SESSION_UI_URL=http://localhost:6080/vnc.html?autoconnect=1&resize=scale
YOUTUBE_LOGIN_EMAIL=
YOUTUBE_LOGIN_PASSWORD=
