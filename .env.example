# =============================================
# БАЗОВЫЕ НАСТРОЙКИ DJANGO
# =============================================
DEBUG=True
SILK_ENABLED=True
SECRET_KEY=your-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=localhost,127.0.0.1

# =============================================
# БАЗА ДАННЫХ (PostgreSQL)
# =============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/postgres

# =============================================
# НАСТРОЙКИ Discogs API
# =============================================
DISCOGS_API_KEY=your-discogs-key
DISCOGS_USER_AGENT=YourAppName/1.0
DISCOGS_COLLECTION_USERNAME=DubplateSpecial

# =============================================
# НАСТРОЙКИ SMS API
# =============================================
SMS_API_KEY=your-api-key
SMS_PROVIDER=sms_ru
SMS_TEST_MODE=True

# =============================================
# НАСТРОЙКИ CELERY
# =============================================
CELERY_BROKER_URL = 'redis://redis:6379/0'  # или ваш брокер
CELERY_RESULT_BACKEND = 'redis://redis:6379/0'
#CELERY_ACCEPT_CONTENT = ['json']
#CELERY_TASK_SERIALIZER = 'json'
#CELERY_RESULT_SERIALIZER = 'json'
#CELERY_TIMEZONE = 'UTC'
#CELERY_ENABLE_UTC = True