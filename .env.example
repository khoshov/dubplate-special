# =============================================
# БАЗОВЫЕ НАСТРОЙКИ DJANGO
# =============================================
RUN_ENV=docker
# RUN_ENV=prod
DEBUG=True
SILK_ENABLED=True
SECRET_KEY=your-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# =============================================
# БАЗА ДАННЫХ (PostgreSQL)
# =============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
# Для docker: `postgres`
# Для prod по умолчанию используется `127.0.0.1`, но можно переопределить
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# =============================================
# TIME / LOGGING
# =============================================
# TIME_ZONE=Europe/Moscow

# =============================================
# НАСТРОЙКИ ЛОГИРОВАНИЯ
# =============================================
APP_LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=WARNING
APP_LOG_FORMAT=text
APP_LOG_DESTINATION=stdout
APP_LOG_COLOR=true
APP_LOG_FILE_PATH=logs/app.log

# =============================================
# НАСТРОЙКИ CELERY / REDIS
# =============================================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# =============================================
# НАСТРОЙКИ Discogs API
# =============================================
DISCOGS_API_KEY=
DISCOGS_USER_AGENT=VinylCatalog/1.0
DISCOGS_COLLECTION_USERNAME=DubplateSpecial

# =============================================
# НАСТРОЙКИ SMS API
# =============================================
SMS_API_KEY=
SMS_PROVIDER=sms_ru
SMS_TEST_MODE=True

# =============================================
# НАСТРОЙКИ ДЛЯ МОДУЛЯ yt-dlp
# =============================================
# docker defaults:
YOUTUBE_BROWSER_PROFILE_DIR=/app/runtime/youtube-browser-profile
YOUTUBE_SESSION_LOCK_FILE=/app/runtime/youtube-session-refresh.lock
YOUTUBE_YTDLP_CACHE_DIR=/app/runtime/yt-dlp-cache
YOUTUBE_SESSION_UI_URL=http://localhost:6080/vnc.html?autoconnect=1&resize=scale
YOUTUBE_JS_RUNTIME=deno
YOUTUBE_JS_RUNTIME_PATH=/usr/local/bin/deno
YOUTUBE_LOGIN_EMAIL=
YOUTUBE_LOGIN_PASSWORD=

# prod example:
# YOUTUBE_BROWSER_PROFILE_DIR=/srv/dubplate-special/runtime/youtube-browser-profile
# YOUTUBE_SESSION_LOCK_FILE=/srv/dubplate-special/runtime/youtube-session-refresh.lock
# YOUTUBE_YTDLP_CACHE_DIR=/srv/dubplate-special/runtime/yt-dlp-cache
# YOUTUBE_SESSION_UI_URL=https://example.com/youtube-session/vnc.html?autoconnect=1&resize=scale&host=example.com&port=443&encrypt=1&path=youtube-session/websockify
# YOUTUBE_JS_RUNTIME=node
# YOUTUBE_JS_RUNTIME_PATH=/usr/bin/node

# =============================================
# НАСТРОЙКИ VK_API
# =============================================
VK_GROUP_ID=
VK_ACCESS_TOKEN=

# =============================================
# MEDIA
# =============================================
# docker/local default: `<BASE_DIR>/media`
# prod default: `/mnt/yadisk/app-media`
# MEDIA_ROOT=/mnt/yadisk/app-media
